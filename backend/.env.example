# Copy to .env and fill in real values
DEBUG=True
SECRET_KEY=change-me-to-50-char-random
JWT_SIGNING_KEY=change-me-to-50-char-random
JWT_AUDIENCE=costco-saver-api
JWT_ISSUER=costco-saver
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — in Docker use host `db`; for local (non-Docker) dev use localhost
DATABASE_URL=postgres://costco_saver:costco_saver_dev@db:5432/costco_saver

# Celery / Redis — in Docker use host `redis`
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Receipt parsing — self-hosted vision LLM endpoint (Kevin's GPU box)
# RECEIPT_LLM_API_KEY is a SECRET bearer token: keep in .env only, NEVER commit.
RECEIPT_LLM_BASE_URL=
RECEIPT_LLM_MODEL=qwen3.6-27B
RECEIPT_LLM_API_KEY=
RECEIPT_LLM_TIMEOUT=300

# Email (dev — uses console backend if not set)
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@example.com
